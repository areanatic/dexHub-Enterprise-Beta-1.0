# DexHub Session Anchor — Worktree Identity Declaration
#
# PURPOSE: This file exists so any session (human or AI) can disambiguate
# "which repo am I actually in?" before doing work. It directly addresses
# the 2026-04-19 cross-repo incident where a parallel session misinterpreted
# "next phase" across worktrees and committed DexHub Phase-5.1 work into
# the wrong repository.
#
# HOW TO USE (session-start protocol):
# 1. Read this file first
# 2. Verify repo == expected_repo
# 3. Verify git remote origin matches expected_origin
# 4. Verify branch is in expected_branches
# 5. If ANY mismatch: STOP, run worktree-check, ask user before any write
#
# CHECKED BY: .dexCore/_dev/tools/validate.sh §24 (anchor consistency)

repo_name: "dexHub-Enterprise-Beta-1.0"
repo_role: "Beta product — platform-agnostic instruction set (DexHub framework)"
